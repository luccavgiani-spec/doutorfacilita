# ═══════════════════════════════════════════════════════════════════
# PLANTÃO DIGITAL — variáveis de ambiente
# ═══════════════════════════════════════════════════════════════════
# Copie este arquivo para .env.local e preencha os valores reais.
# NUNCA commit .env.local — ele está no .gitignore.

# ─── Supabase ────────────────────────────────────────────────────────
# Project: plantaodigital (tylpojscdbkzulykdguv)
# Region: sa-east-1
NEXT_PUBLIC_SUPABASE_URL=https://tylpojscdbkzulykdguv.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── LiveKit ─────────────────────────────────────────────────────────
# Tier: Build (free, 5k min/mês). Migrar pra Ship ($50/mês) quando precisar SLA.
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud

# ─── Mevo (Prescrição Digital) ───────────────────────────────────────
# Token: Base64(login:senha). Usado SOMENTE no backend (edge function).
MEVO_AUTH_TOKEN=
MEVO_BASE_URL=https://emr-homolog.nexodata.com.br
MEVO_SUBPARCEIRO=plantaodigital

# ─── Mercado Pago (preparação futura) ────────────────────────────────
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=
